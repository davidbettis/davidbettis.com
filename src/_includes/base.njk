---
title: David Bettis
description: Software engineer and technologist in the Pacific Northwest.
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- SEO Meta Tags -->
    <meta name="description" content="{{ description }}">
    <link rel="canonical" href="https://davidbettis.com{{ page.url }}">

    <!-- Open Graph Tags -->
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:type" content="{% if date %}article{% else %}website{% endif %}">
    <meta property="og:url" content="https://davidbettis.com{{ page.url }}">

    <!-- Font Preloading -->
    <link rel="preload" href="/fonts/socialfont.woff" as="font" type="font/woff" crossorigin>

    <!-- Stylesheets -->
    <link rel="stylesheet" href="/assets/css/site.css?v={{ version }}">
    <link rel="stylesheet" href="/assets/css/social-circles.min.css?v={{ version }}">
    <title>{{ title }}</title>
  </head>
  <body>
    <nav>
      <div class="nav-header">
        <div class="nav-title">
          <span class="site-name">David Bettis<span class="name-ref"><span class="name-footnote">*</span></span></span>
        </div>
        <span class="nav-social">
          <a href="https://www.linkedin.com/in/davidbettis/" class="icon-linkedin social-button color"></a>
          <a href="https://github.com/davidbettis" class="icon-github social-button color"></a>
        </span>
      </div>
      <div class="nav-links">
        <a href="/"{% if page.url == "/" %} aria-current="page"{% endif %}>Posts</a>
        <span class="nav-sep">&raquo;</span>
        <a href="/projects/"{% if page.url == "/projects/" %} aria-current="page"{% endif %}>Projects</a>
        <span class="nav-sep">&raquo;</span>
        <a href="/places/"{% if page.url == "/places/" %} aria-current="page"{% endif %}>Places</a>
      </div>
      <p class="name-tooltip">Software engineer and technologist from the Pacific Northwest.</p>
    </nav>
    <div class='content'>
      {% block body %}
        {{ content | safe }}
      {% endblock %}
    </div>
  </body>
</html>

